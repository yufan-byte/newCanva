# Infinite Canvas 环境变量配置示例
# 复制此文件为 .env 并填入你的配置

# 服务端口（默认 3000）
# PORT=3000

# 数据存储根目录（Docker 中默认 /app/data_root，本地运行默认为主程序目录）
# DATA_ROOT=/app/data_root

# API 配置（也可在 Web 界面左下角设置）
# API_KEY=your-api-key-here
# API_BASE_URL=https://api.apimart.ai

# ModelScope（免费生成）
# MODELSCOPE_API_KEY=your-modelscope-key

# ComfyUI 实例地址
# COMFYUI_INSTANCES=127.0.0.1:8188

# 公网访问地址（部署到服务器后设置）
# PUBLIC_BASE_URL=https://your-domain.com
# PUBLIC_MEDIA_BASE_URL=https://your-domain.com
