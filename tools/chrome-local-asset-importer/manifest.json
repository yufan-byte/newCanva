{
  "manifest_version": 3,
  "name": "Infinite Canvas 本地素材导入",
  "description": "扫描当前网页图片，批量导入 Infinite Canvas 本地素材并可调用智能分类。",
  "version": "1.0.0",
  "action": {
    "default_popup": "popup.html",
    "default_title": "导入本地素材",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "background": {
    "service_worker": "background.js"
  },
  "permissions": [
    "activeTab",
    "scripting",
    "storage",
    "sidePanel",
    "webRequest",
    "downloads"
  ],
  "host_permissions": [
    "http://*/*",
    "https://*/*"
  ]
}
